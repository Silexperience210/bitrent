# BitRent Backend - Staging Environment
# Mirrors production but with non-critical settings

NODE_ENV=staging
PORT=3000
LOG_LEVEL=debug

# Database (Supabase Staging)
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Configuration
JWT_SECRET=your-staging-secret-string-min-32-characters-for-staging
JWT_EXPIRY=7d

# NWC (Nostr Wallet Connect) - Test/Staging
NWC_RELAY_URL=wss://relay.staging.bitcoin.co
NWC_PUBKEY=your-staging-nwc-pubkey
NWC_SECRET=your-staging-nwc-secret

# Admin Configuration
ADMIN_NOSTR_PUBKEY=your-staging-admin-pubkey

# CORS & API
CORS_ORIGIN=https://staging.bitrent.io,http://localhost:3000
API_BASE_URL=https://api-staging.bitrent.io

# Blockchain (Testnet)
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=https://btc-testnet.example.com
BITCOIN_RPC_USER=your-rpc-user
BITCOIN_RPC_PASS=your-rpc-pass

# Monitoring & Observability
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.5
SENTRY_RELEASE=1.0.0-staging

DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DESTINATION=syslog

# Rate Limiting (relaxed for testing)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Security
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
HELMET_ENABLED=true

# Email (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=staging@bitrent.io

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * * # 3 AM daily
BACKUP_RETENTION_DAYS=14
BACKUP_STORAGE=s3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=bitrent-backups-staging
AWS_REGION=eu-west-1

# Feature Flags (enable all for testing)
ENABLE_PAYMENT_PROCESSING=true
ENABLE_MINING_RENTAL=true
ENABLE_ADMIN_DASHBOARD=true
FEATURE_FLAG_BETA_UI=true

# Cache
REDIS_URL=redis://redis-staging.example.com:6379
CACHE_TTL=3600

# Third-party Services (Stripe test keys)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_test_your-webhook-secret

ANALYTICS_TOKEN=your-analytics-token
ANALYTICS_DOMAIN=staging.bitrent.io
