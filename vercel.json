{
  "version": 2,
  "buildCommand": "cd packages/backend && npm install",
  "public": "public",
  "api": {
    "builder": "@vercel/node",
    "src": "api/**/*.js"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SERVICE_KEY": "@supabase_service_key",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
