# Supabase Configuration (get from supabase.com dashboard)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Authentication (generate random string)
JWT_SECRET=
JWT_EXPIRY=7d

# Nostr & Payments (from Alby/wallet)
NWC_CONNECTION_STRING=
NWC_RELAY=wss://relay.getalby.com/v1
ADMIN_PUBKEYS=

# Environment
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Optional: Monitoring (Sentry)
SENTRY_DSN=
