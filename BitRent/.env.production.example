# BitRent Production Environment Variables
# ⚠️  CRITICAL: Store these in a secure secrets manager (Railway, AWS Secrets Manager, etc.)
# NEVER commit actual secrets to version control!

# Environment
NODE_ENV=production
LOG_LEVEL=warn

# API
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=/api/v1

# Database (Production Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@db.production.supabase.co:5432/postgres

# Redis (Production)
REDIS_URL=redis://:PASSWORD@redis-production.internal:6379

# JWT (Generate a strong random key)
JWT_SECRET=CHANGE_ME_TO_A_VERY_STRONG_SECRET_KEY_WITH_HIGH_ENTROPY
JWT_EXPIRES_IN=24h

# Supabase (Production)
SUPABASE_URL=https://production.supabase.co
SUPABASE_ANON_KEY=PRODUCTION_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=PRODUCTION_SERVICE_KEY_HERE

# Stripe (Production Keys)
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_live_

# Nostr Wallet Connect (Production wallet)
NWC_RELAY_URL=wss://relay.primal.net/v1
NWC_APP_NAME=bitrent
NWC_SECRET=PRODUCTION_NWC_SECRET

# CORS (Strict production CORS)
CORS_ORIGIN=https://bitrent.io,https://www.bitrent.io

# Email (SendGrid for production)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.PRODUCTION_SENDGRID_API_KEY
SMTP_FROM=noreply@bitrent.io

# GitHub OAuth (Production)
GITHUB_CLIENT_ID=PRODUCTION_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=PRODUCTION_GITHUB_CLIENT_SECRET

# Twitter/X API (Production)
TWITTER_API_KEY=PRODUCTION_TWITTER_KEY
TWITTER_API_SECRET=PRODUCTION_TWITTER_SECRET

# Bitcoin (Mainnet)
BITCOIN_NETWORK=mainnet
BITCOIN_RPC_URL=https://blockstream.info/api
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Logging
LOG_TO_FILE=true
LOG_DIR=/var/log/bitrent
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# Monitoring & Error Tracking
SENTRY_DSN=https://PRODUCTION_SENTRY_DSN@sentry.io/PROJECT_ID
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1

# Datadog APM
DATADOG_API_KEY=PRODUCTION_DATADOG_API_KEY
DATADOG_ENV=production
DATADOG_SERVICE=bitrent
DATADOG_VERSION=1.0.0

# Feature Flags
FEATURE_BETA_TESTING=false
FEATURE_ADVANCED_ANALYTICS=true

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=PRODUCTION_BACKUP_ENCRYPTION_KEY

# Cloudflare (Production)
CLOUDFLARE_API_TOKEN=PRODUCTION_CLOUDFLARE_TOKEN
CLOUDFLARE_ZONE_ID=PRODUCTION_ZONE_ID
CLOUDFLARE_PURGE_CACHE_ON_DEPLOY=true

# Uptime Monitoring
UPTIME_ROBOT_API_KEY=PRODUCTION_UPTIME_ROBOT_KEY

# PagerDuty (Incident Management)
PAGERDUTY_INTEGRATION_KEY=PRODUCTION_PAGERDUTY_KEY

# Slack (Notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Database Replication
DB_REPLICA_URL=postgresql://postgres:PASSWORD@db-replica.production.supabase.co:5432/postgres

# CDN
CDN_URL=https://cdn.bitrent.io
CDN_PURGE_ENABLED=true

# Analytics
ANALYTICS_ENABLED=true
AMPLITUDE_API_KEY=PRODUCTION_AMPLITUDE_KEY

# KYC/AML (if required)
KYC_PROVIDER_API_KEY=PRODUCTION_KYC_API_KEY
KYC_ENABLED=false

# Webhook Signing Secret
WEBHOOK_SIGNING_SECRET=PRODUCTION_WEBHOOK_SIGNING_SECRET

# Performance
MAX_REQUEST_SIZE=20mb
COMPRESSION_ENABLED=true
CACHE_TTL_SECONDS=1800
