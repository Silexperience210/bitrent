# BitRent Backend - Production Environment
# Copy this to .env and fill in with actual values
# NEVER commit .env to version control

# Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database (Supabase Production)
SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Configuration
JWT_SECRET=your-super-secure-random-string-min-32-characters-long-for-production
JWT_EXPIRY=7d

# NWC (Nostr Wallet Connect) - Production
NWC_RELAY_URL=wss://relay.bitcoin.co
NWC_PUBKEY=your-production-nwc-pubkey
NWC_SECRET=your-production-nwc-secret

# Admin Configuration
ADMIN_NOSTR_PUBKEY=your-admin-pubkey-for-production

# CORS & API
CORS_ORIGIN=https://bitrent.io,https://www.bitrent.io
API_BASE_URL=https://api.bitrent.io

# Blockchain
BITCOIN_NETWORK=mainnet
BITCOIN_RPC_URL=https://btc-mainnet.example.com
BITCOIN_RPC_USER=your-rpc-user
BITCOIN_RPC_PASS=your-rpc-pass

# Monitoring & Observability
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=1.0.0

DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DESTINATION=syslog

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
HELMET_ENABLED=true

# Email (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@bitrent.io

# Backup & Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=bitrent-backups-prod
AWS_REGION=eu-west-1

# Feature Flags
ENABLE_PAYMENT_PROCESSING=true
ENABLE_MINING_RENTAL=true
ENABLE_ADMIN_DASHBOARD=true
FEATURE_FLAG_BETA_UI=false

# Cache
REDIS_URL=redis://redis-prod.example.com:6379
CACHE_TTL=3600

# Third-party Services
STRIPE_PUBLIC_KEY=pk_live_your-stripe-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

ANALYTICS_TOKEN=your-analytics-token
ANALYTICS_DOMAIN=bitrent.io
