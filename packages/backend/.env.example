# Environment
NODE_ENV=production

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# JWT Configuration
JWT_SECRET=your-super-secret-key-min-32-chars-long-please
JWT_EXPIRES_IN=24h

# Admin Configuration
ADMIN_NOSTR_PUBKEY=your-admin-nostr-public-key-64-hex-chars

# NWC (Nostr Wallet Connect) Configuration
NWC_WALLET_PUB=your-nwc-wallet-public-key
NWC_CONNECTION_SECRET=your-nwc-connection-secret

# CORS Configuration
CORS_ORIGIN=https://bitrent.vercel.app,http://localhost:3000

# API Configuration
API_PORT=3000

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true
LOG_LEVEL=info
