# BitRent Staging Environment Variables
# Copy this file to .env.staging and fill in your values

# Environment
NODE_ENV=production
LOG_LEVEL=info

# API
API_PORT=3000
API_HOST=0.0.0.0
API_PREFIX=/api/v1

# Database (Staging Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@db.staging.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://:PASSWORD@redis-staging.internal:6379

# JWT
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_KEY
JWT_EXPIRES_IN=24h

# Supabase (Staging)
SUPABASE_URL=https://staging.supabase.co
SUPABASE_ANON_KEY=STAGING_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=STAGING_SERVICE_KEY_HERE

# Stripe (Test Keys - same for staging and production testing)
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# Nostr Wallet Connect (Test wallet)
NWC_RELAY_URL=wss://relay.getalby.com/v1
NWC_APP_NAME=bitrent-staging

# CORS
CORS_ORIGIN=https://staging.bitrent.io

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@staging.bitrent.io

# GitHub OAuth
GITHUB_CLIENT_ID=STAGING_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=STAGING_GITHUB_CLIENT_SECRET

# Twitter/X API
TWITTER_API_KEY=STAGING_TWITTER_KEY
TWITTER_API_SECRET=STAGING_TWITTER_SECRET

# Bitcoin
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=https://testnet.blockexplorer.com/api
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Logging
LOG_TO_FILE=true
LOG_DIR=/var/log/bitrent

# Monitoring
SENTRY_DSN=https://STAGING_SENTRY_DSN@sentry.io/PROJECT_ID
DATADOG_API_KEY=STAGING_DATADOG_API_KEY

# Feature Flags
FEATURE_BETA_TESTING=true
FEATURE_ADVANCED_ANALYTICS=true

# Testing
TEST_MODE=false
SEED_DATABASE=false

# Backup
BACKUP_ENABLED=true
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=7

# Cloudflare
CLOUDFLARE_API_TOKEN=STAGING_CLOUDFLARE_TOKEN
CLOUDFLARE_ZONE_ID=STAGING_ZONE_ID

# Uptime Monitoring
UPTIME_ROBOT_API_KEY=STAGING_UPTIME_ROBOT_KEY
