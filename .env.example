# Supabase (from supabase.com dashboard > Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NOT anon key)

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRY=7d

# Nostr Wallet Connect (from Alby: Settings > Nostr Wallet Connect)
# Format: nostr+walletconnect://<walletPubkey>?relay=<relayUrl>&secret=<clientSecret>
NWC_CONNECTION_STRING=nostr+walletconnect://...

# Admin Nostr pubkeys (hex, comma-separated)
ADMIN_PUBKEYS=

# Cron security (generate: openssl rand -hex 16)
CRON_SECRET=

# Environment
NODE_ENV=production
