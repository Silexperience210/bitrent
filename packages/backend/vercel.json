{
  "version": 2,
  "framework": "nodejs",
  "public": "public",
  "buildCommand": "npm run build",
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "env": {
    "NODE_ENV": "@node_env",
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "JWT_SECRET": "@jwt_secret",
    "JWT_EXPIRES_IN": "@jwt_expires_in",
    "ADMIN_NOSTR_PUBKEY": "@admin_nostr_pubkey",
    "NWC_WALLET_PUB": "@nwc_wallet_pub",
    "NWC_CONNECTION_SECRET": "@nwc_connection_secret",
    "CORS_ORIGIN": "@cors_origin"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
