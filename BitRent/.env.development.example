# BitRent Development Environment Variables
# Copy this file to .env.development and fill in your values

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# API
API_PORT=3000
API_HOST=localhost
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://bitrent:dev_password@localhost:5432/bitrent_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Supabase
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
SUPABASE_SERVICE_KEY=

# Stripe (Test Keys)
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_test_

# Nostr Wallet Connect
NWC_RELAY_URL=wss://relay.getalby.com/v1
NWC_APP_NAME=bitrent-dev

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email (Mailhog in development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@bitrent.local

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Twitter/X
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Bitcoin
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Logging
LOG_TO_FILE=false
LOG_DIR=./logs

# Feature Flags
FEATURE_BETA_TESTING=true
FEATURE_ADVANCED_ANALYTICS=true

# Testing
TEST_MODE=true
SEED_DATABASE=true
